{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "builds": [
    {
      "src": "backend/server.mjs",
      "use": "@vercel/node",
      "config": {
        "runtime": "nodejs18.x"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.mjs"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/dist/assets/$1"
    },
    {
      "src": "/manifest.webmanifest",
      "dest": "/frontend/dist/manifest.webmanifest"
    },
    {
      "src": "/sw.js",
      "dest": "/frontend/dist/sw.js"
    },
    {
      "src": "/workbox-(.+)\\.js",
      "dest": "/frontend/dist/workbox-$1.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
